# World ID — get these from https://developer.world.org
NEXT_PUBLIC_APP_ID=app_xxxxx
WLD_RP_ID=rp_xxxxx
WLD_SIGNING_KEY=sk_xxxxx

# Contract (set after deploy)
PRIVATE_KEY=0x_your_deployer_private_key
WORLD_CHAIN_RPC=https://worldchain-mainnet.g.alchemy.com/public
HUMANGATE_CONTRACT_ADDRESS=0x_deployed_contract_address
HUMANGATE_RESOLVER_ADDRESS=0x_deployed_resolver_address

# Public (exposed to browser)
NEXT_PUBLIC_HUMANGATE_CONTRACT=0x_deployed_contract_address
NEXT_PUBLIC_RESOLVER_CONTRACT=0x_deployed_resolver_address

# JWT
JWT_SECRET=change-me-to-a-random-secret
